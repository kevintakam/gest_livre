{% extends 'base.html.twig' %}

{% block title %}Mes Livres{% endblock %}

{% block body %}
<main class="books-page">
    <header class="books-header">
        <h1>📚 Mes Livres</h1>
        <a href="{{ path('app_book_new') }}" class="btn btn-primary">
            + Ajouter un livre
        </a>
    </header>

    {% if books is empty %}
        <section class="empty-state">
            <p>Aucun livre pour l’instant.</p>
            <a href="{{ path('app_book_new') }}" class="btn btn-primary">
                Ajouter le premier livre
            </a>
        </section>
    {% else %}
        <div class="books-table-wrapper">
            <table class="books-table">
                <thead>
                    <tr>
                        <th>Titre</th>
                        <th>Auteur</th>
                        <th>ISBN</th>
                        <th>Année</th>
                        <th>Propriétaire</th>
                        <th>Actions</th>
                    </tr>
                </thead>

                <tbody>
                {% for book in books %}
                    <tr>
                        <td>
                            <a class="book-title-link" href="{{ path('app_book_show', {id: book.id}) }}">
                                {{ book.title }}
                            </a>
                        </td>
                        <td>{{ book.author }}</td>
                        <td>{{ book.isbn ?? '—' }}</td>
                        <td>{{ book.publishedYear ?? '—' }}</td>
                        <td>{{ book.owner.email }}</td>
                        <td>
                            {% if app.user == book.owner %}
                                <div class="actions">
                                    <a class="btn btn-secondary" href="{{ path('app_book_edit', {id: book.id}) }}">
                                        ✏️ Modifier
                                    </a>

                                    <form class="inline-form"
                                          method="POST"
                                          action="{{ path('app_book_delete', {id: book.id}) }}"
                                          data-confirm="Supprimer ce livre ?">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete_book_' ~ book.id) }}">
                                        <button class="btn btn-danger" type="submit">
                                            🗑️ Supprimer
                                        </button>
                                    </form>
                                </div>
                            {% else %}
                                —
                            {% endif %}
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    {% endif %}
</main>
{% endblock %}