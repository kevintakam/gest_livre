{% extends 'base.html.twig' %}

{% block title %}Connexion{% endblock %}

{% block body %}
<main class="auth-page">
    <section class="auth-card">

        <div class="auth-decoration auth-decoration-top"></div>
        <div class="auth-decoration auth-decoration-bottom"></div>

        <header class="auth-header">
            <h1>Welcome back</h1>
            <p>Welcome back! Please enter your details.</p>
        </header>

        {% if error %}
            <div class="auth-alert">
                {{ error.messageKey|trans(error.messageData, 'security') }}
            </div>
        {% endif %}

        {{ form_start(form, {
            action: path('app_login'),
            method: 'POST',
            attr: { class: 'auth-form' }
        }) }}

            <div class="auth-field">
                <label>Email</label>
                {{ form_widget(form.email, {
                    attr: {
                        class: 'auth-input',
                        value: last_email,
                        placeholder: 'Enter your email',
                        autocomplete: 'email'
                    }
                }) }}
            </div>

            <div class="auth-field">
                <label>Password</label>
                {{ form_widget(form.password, {
                    attr: {
                        class: 'auth-input',
                        placeholder: '••••••••',
                        autocomplete: 'current-password'
                    }
                }) }}
            </div>

            <div class="auth-options">
                <label class="auth-checkbox">
                    <input type="checkbox" name="_remember_me">
                    <span>Remember for 30 days</span>
                </label>

                <a href="#" class="auth-link">Forgot password?</a>
            </div>

            <button type="submit" class="auth-submit">
                Sign in
            </button>

        {{ form_end(form, { render_rest: false }) }}

        <button type="button" class="auth-google">
            <span class="google-icon">G</span>
            Sign in with Google
        </button>

        <p class="auth-footer">
            Don’t have an account?
            <a href="{{ path('app_register') }}">Sign up</a>
        </p>
    </section>
</main>
{% endblock %}