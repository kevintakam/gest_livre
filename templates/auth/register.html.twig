{% extends 'base.html.twig' %}

{% block title %}Inscription{% endblock %}

{% block body %}
<main class="auth-page">
    <section class="auth-card auth-card-register">

        <div class="auth-decoration auth-decoration-top"></div>
        <div class="auth-decoration auth-decoration-bottom"></div>

        <header class="auth-header">
            <h1>Create account</h1>
            <p>Start managing your books in a few seconds.</p>
        </header>

        {{ form_start(form, {
            attr: {
                class: 'auth-form',
                'data-turbo': 'false'
            }
        }) }}

            {% if form.vars.errors|length %}
                <div class="auth-alert">
                    <ul>
                        {% for error in form.vars.errors %}
                            <li>{{ error.message }}</li>
                        {% endfor %}
                    </ul>
                </div>
            {% endif %}

            <div class="auth-field">
                <label>Email</label>
                {{ form_widget(form.email, {
                    attr: {
                        class: 'auth-input',
                        placeholder: 'Enter your email',
                        autocomplete: 'email'
                    }
                }) }}
                <div class="auth-field-error">
                    {{ form_errors(form.email) }}
                </div>
            </div>

            <div class="auth-field">
                <label>Password</label>
                {{ form_widget(form.plainPassword.first, {
                    attr: {
                        class: 'auth-input',
                        placeholder: 'Create a password',
                        autocomplete: 'new-password'
                    }
                }) }}
                <div class="auth-field-error">
                    {{ form_errors(form.plainPassword.first) }}
                </div>
            </div>

            <div class="auth-field">
                <label>Confirm password</label>
                {{ form_widget(form.plainPassword.second, {
                    attr: {
                        class: 'auth-input',
                        placeholder: 'Confirm your password',
                        autocomplete: 'new-password'
                    }
                }) }}
                <div class="auth-field-error">
                    {{ form_errors(form.plainPassword.second) }}
                </div>
            </div>

            <button type="submit" class="auth-submit">
                Sign up
            </button>

        {{ form_end(form, { render_rest: false }) }}

        <p class="auth-footer">
            Already have an account?
            <a href="{{ path('app_login') }}">Sign in</a>
        </p>
    </section>
</main>
{% endblock %}